local function getFolderList(path)
  local list = {}
  local files = File(path).listFiles()
  if files then 
    for i = 0, #files - 1 do 
      if files[i].isDirectory() then 
        local checkMainFile = File(files[i].getAbsolutePath() .. "/main.lua")
        if checkMainFile.exists() and checkMainFile.isFile() then
          table.insert(list, tostring(files[i].getName())) 
        end
      end 
    end 
  end
  return list
end

