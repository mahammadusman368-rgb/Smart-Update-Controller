local function makeStrictRawLink(url)
  if not url or url == "" then return "" end
  url = url:gsub("^%s*(.-)%s*$", "%1")
  if url:find("github.com") and not url:find("raw.githubusercontent.com") then
    url = url:gsub("github.com", "raw.githubusercontent.com"):gsub("/blob/", "/")
    if url:find("%?") then url = url:match("([^%?]+)") end
  end
  return url:gsub(" ", "%%20")
end

local function safeLiteralReplace(str, placeholder, extraValue)
  local escapedValue = extraValue:gsub("%%", "%%%%")
  return str:gsub(placeholder, escapedValue)
end

local function xorCipherEncrypt(data, key)
  local t = {}
  for i = 1, #data do
    local b = data:byte(i)
    table.insert(t, string.format("%02x", bit32.bxor(b, key)))
  end
  return table.concat(t)
end

